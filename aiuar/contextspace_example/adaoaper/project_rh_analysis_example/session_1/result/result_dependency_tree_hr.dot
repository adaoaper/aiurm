// aiurm_marker: [*result_dependency_tree_hr]
// aiuar_address: *****contextspace_example****adaoaper***project_rh_analysis_example**session_1*result_dependency_tree_hr
// execution_id: 20260329_f3a9b1
// step: R14. Dependency tree results
// Paste this into: https://dreampuf.github.io/GraphvizOnline/

digraph aiurm_rh_analysis_example {
  rankdir=LR;
  node [shape=box, style=filled, fontname="Helvetica", fontsize=10];

  // === DATA NODES ===
  subgraph cluster_data {
    label="Data";
    style=filled;
    color="#e8f4e8";
    node [fillcolor="#b7e1b7"];
    data_employees       [label="*data_employees"];
    data_perf_rules      [label="*data_performance_rules"];
    data_retention_rules [label="*data_retention_rules"];
    data_promo_scenarios [label="*data_promotion_scenarios"];
    data_output_cfg      [label="*data_output_configuration"];
    gov                  [label="*aiurm_governance_rh_analysis_example", shape=note, fillcolor="#d0e8ff"];
  }

  // === LOGIC NODES ===
  subgraph cluster_logic {
    label="Logic";
    style=filled;
    color="#fef9e7";
    node [fillcolor="#fdeaa7"];
    l_perf   [label="*logic_performance_analysis_hr"];
    l_ret    [label="*logic_retention_analysis_hr"];
    l_dept   [label="*logic_department_summary_hr"];
    l_plan   [label="*logic_hr_action_plan"];
    l_dash   [label="*logic_executive_dashboard_hr"];
    l_cons   [label="*logic_conservative_promotions_hr"];
    l_agg    [label="*logic_aggressive_promotions_hr"];
    l_scen   [label="*logic_scenario_comparison_hr"];
    l_rfp    [label="*logic_ready_for_promotion_filter_hr"];
    l_filt   [label="*logic_hr_filters_hr"];
    l_expl   [label="*logic_explainability_hr"];
    l_trace  [label="*logic_transformation_trace_hr"];
    l_json   [label="*logic_json_export_performance_hr"];
    l_dep    [label="*logic_dependency_tree_hr"];
  }

  // === RESULT NODES ===
  subgraph cluster_result {
    label="Result";
    style=filled;
    color="#fce8e8";
    node [fillcolor="#f5b7b1"];
    r_perf   [label="*result_performance_analysis\n(R1)"];
    r_ret    [label="*result_retention_analysis\n(R2)"];
    r_dept   [label="*result_department_summary\n(R3)"];
    r_plan   [label="*result_hr_action_plan\n(R4)"];
    r_dash   [label="*result_executive_dashboard\n(R5)"];
    r_cons   [label="*result_conservative_promotions\n(R6)"];
    r_agg    [label="*result_aggressive_promotions\n(R7)"];
    r_scen   [label="*result_scenario_comparison\n(R8)"];
    r_rfp    [label="*result_ready_for_promotion_filter_hr\n(R9)"];
    r_filt   [label="*result_hr_filters_hr\n(R10)"];
    r_expl   [label="*result_explainability_hr\n(R11)"];
    r_trace  [label="*result_transformation_trace_hr\n(R12)"];
    r_json   [label="*result_json_performance_hr\n(R13)"];
    r_dep    [label="*result_dependency_tree_hr\n(R14)"];
  }

  // === R1: Performance analysis ===
  data_employees  -> r_perf;
  data_perf_rules -> r_perf;
  l_perf          -> r_perf;

  // === R2: Retention analysis ===
  data_employees       -> r_ret;
  data_retention_rules -> r_ret;
  l_ret                -> r_ret;

  // === R3: Department summary ===
  data_employees -> r_dept;
  r_perf         -> r_dept;
  r_ret          -> r_dept;
  data_output_cfg -> r_dept;
  l_dept         -> r_dept;

  // === R4: HR action plan ===
  r_perf          -> r_plan;
  r_ret           -> r_plan;
  data_output_cfg -> r_plan;
  l_plan          -> r_plan;

  // === R5: Executive dashboard ===
  r_perf          -> r_dash;
  r_ret           -> r_dash;
  r_dept          -> r_dash;
  data_output_cfg -> r_dash;
  l_dash          -> r_dash;

  // === R6: Conservative promotions ===
  data_employees      -> r_cons;
  data_promo_scenarios -> r_cons;
  l_cons              -> r_cons;

  // === R7: Aggressive promotions ===
  data_employees       -> r_agg;
  data_promo_scenarios -> r_agg;
  l_agg                -> r_agg;

  // === R8: Scenario comparison ===
  r_cons          -> r_scen;
  r_agg           -> r_scen;
  data_output_cfg -> r_scen;
  l_scen          -> r_scen;

  // === R9: Ready-for-promotion filter ===
  data_employees -> r_rfp;
  r_perf         -> r_rfp;
  l_rfp          -> r_rfp;

  // === R10: Quick filters ===
  r_perf  -> r_filt;
  r_ret   -> r_filt;
  r_dept  -> r_filt;
  l_filt  -> r_filt;

  // === R11: Explainability ===
  r_perf  -> r_expl;
  r_ret   -> r_expl;
  r_agg   -> r_expl;
  r_scen  -> r_expl;
  l_expl  -> r_expl;

  // === R12: Transformation trace ===
  data_employees -> r_trace;
  r_perf         -> r_trace;
  r_cons         -> r_trace;
  r_agg          -> r_trace;
  l_trace        -> r_trace;

  // === R13: JSON export performance ===
  r_perf  -> r_json;
  l_json  -> r_json;

  // === R14: Dependency tree ===
  gov    -> r_dep;
  r_perf  -> r_dep;
  r_ret   -> r_dep;
  r_dept  -> r_dep;
  r_plan  -> r_dep;
  r_dash  -> r_dep;
  r_cons  -> r_dep;
  r_agg   -> r_dep;
  r_scen  -> r_dep;
  r_rfp   -> r_dep;
  r_filt  -> r_dep;
  r_expl  -> r_dep;
  r_trace -> r_dep;
  r_json  -> r_dep;
  l_dep   -> r_dep;
}
